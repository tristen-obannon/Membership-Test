:root {
  --bg: #f3efe4;
  --bg-accent: #efe2c2;
  --panel: rgba(255, 250, 240, 0.92);
  --panel-strong: #fffaf0;
  --text: #1f2933;
  --muted: #5b6470;
  --border: rgba(56, 67, 80, 0.14);
  --shadow: 0 18px 45px rgba(61, 49, 27, 0.12);
  --active: #0f766e;
  --lifetime: #d97706;
  --other: #64748b;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  font-family: "Source Sans 3", Georgia, serif;
  color: var(--text);
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.9), transparent 30%),
    linear-gradient(135deg, var(--bg) 0%, var(--bg-accent) 100%);
}

code {
  font-family: "Space Grotesk", sans-serif;
  font-size: 0.95em;
}

.page-shell {
  width: min(1180px, calc(100% - 32px));
  margin: 0 auto;
  padding: 32px 0 48px;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 24px;
  align-items: end;
  padding: 28px;
  border: 1px solid var(--border);
  background: linear-gradient(145deg, rgba(255, 252, 246, 0.96), rgba(251, 241, 216, 0.88));
  box-shadow: var(--shadow);
  border-radius: 8px;
}

.eyebrow {
  margin: 0 0 8px;
  font-family: "Space Grotesk", sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--active);
  letter-spacing: 0;
}

.hero h1,
.panel-heading h3,
.kpi-card h2 {
  font-family: "Space Grotesk", sans-serif;
  letter-spacing: 0;
}

.hero h1 {
  margin: 0;
  font-size: clamp(2rem, 4vw, 3.4rem);
  line-height: 1;
}

.hero-copy,
.panel-heading p,
.kpi-card span,
.hero-meta {
  color: var(--muted);
}

.hero-copy {
  max-width: 62ch;
  margin: 12px 0 0;
  font-size: 1.05rem;
}

.hero-meta {
  align-self: start;
  white-space: nowrap;
  padding: 10px 14px;
  border: 1px solid var(--border);
  background: rgba(255, 255, 255, 0.65);
  border-radius: 999px;
  font-family: "Space Grotesk", sans-serif;
  font-weight: 500;
}

main {
  margin-top: 24px;
}

.kpi-grid,
.chart-grid {
  display: grid;
  gap: 20px;
}

.kpi-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.chart-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 20px;
}

.kpi-card,
.panel {
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--panel);
  box-shadow: var(--shadow);
}

.kpi-card {
  padding: 24px;
  position: relative;
  overflow: hidden;
}

.kpi-card::after {
  content: "";
  position: absolute;
  inset: auto -40px -40px auto;
  width: 160px;
  height: 160px;
  border-radius: 50%;
  opacity: 0.08;
}

.active-card::after {
  background: var(--active);
}

.lifetime-card::after {
  background: var(--lifetime);
}

.kpi-card p,
.panel-heading p {
  margin: 0;
}

.kpi-card p {
  font-weight: 700;
  font-size: 1rem;
}

.kpi-card h2 {
  margin: 10px 0 6px;
  font-size: clamp(2.3rem, 7vw, 3.4rem);
  line-height: 1;
}

.active-card h2 {
  color: var(--active);
}

.lifetime-card h2 {
  color: var(--lifetime);
}

.panel {
  padding: 22px;
}

.panel-heading {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: baseline;
  margin-bottom: 18px;
}

.panel-heading h3 {
  margin: 0;
  font-size: 1.15rem;
}

.chart-wrap {
  position: relative;
  min-height: 320px;
}

.table-panel {
  margin-top: 20px;
}

.uploader-panel {
  margin-top: 20px;
}

.uploader-row {
  display: flex;
  gap: 14px;
  align-items: center;
  flex-wrap: wrap;
}

.file-picker {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42px;
  padding: 0 16px;
  border-radius: 999px;
  border: 1px solid var(--border);
  background: #fff;
  font-family: "Space Grotesk", sans-serif;
  font-weight: 700;
  cursor: pointer;
}

#csv-upload {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.source-status {
  color: var(--muted);
}

.table-container {
  overflow: auto;
  max-height: 560px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--panel-strong);
}

table {
  width: 100%;
  border-collapse: collapse;
  min-width: 940px;
}

thead {
  position: sticky;
  top: 0;
  z-index: 1;
}

th,
td {
  padding: 12px 14px;
  text-align: left;
  border-bottom: 1px solid var(--border);
  vertical-align: top;
}

th {
  background: #fdf7eb;
  font-family: "Space Grotesk", sans-serif;
  font-size: 0.92rem;
}

tbody tr:nth-child(even) {
  background: rgba(245, 236, 216, 0.42);
}

.type-badge {
  display: inline-flex;
  align-items: center;
  min-width: 84px;
  justify-content: center;
  padding: 6px 10px;
  border-radius: 999px;
  font-family: "Space Grotesk", sans-serif;
  font-size: 0.84rem;
  font-weight: 700;
}

.type-active {
  background: rgba(15, 118, 110, 0.12);
  color: var(--active);
}

.type-lifetime {
  background: rgba(217, 119, 6, 0.12);
  color: var(--lifetime);
}

.type-other {
  background: rgba(100, 116, 139, 0.12);
  color: var(--other);
}

.error-banner {
  margin-top: 20px;
  padding: 14px 16px;
  border-radius: 8px;
  border: 1px solid rgba(185, 28, 28, 0.25);
  background: rgba(254, 226, 226, 0.9);
  color: #991b1b;
}

.hidden {
  display: none;
}

@media (max-width: 900px) {
  .hero,
  .panel-heading {
    flex-direction: column;
    align-items: start;
  }

  .kpi-grid,
  .chart-grid {
    grid-template-columns: 1fr;
  }

  .chart-wrap {
    min-height: 280px;
  }
}
